<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard Produk</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    /* CHAT BUTTON */
    #chatButton {
      position: fixed;
      bottom: 20px;
      right: 20px;
      width: 60px;
      height: 60px;
      background: #0d6efd;
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      cursor: pointer;
      box-shadow: 0 4px 10px rgba(0,0,0,0.3);
      color: white;
      font-size: 26px;
      z-index: 999;
    }

    /* CHAT POPUP */
    #chatPopup {
      position: fixed;
      bottom: 90px;
      right: 20px;
      width: 320px;
      height: 420px;
      background: white;
      border-radius: 10px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.3);
      display: none;
      flex-direction: column;
      overflow: hidden;
      z-index: 999;
    }

    #chatBox {
      flex: 1;
      padding: 10px;
      overflow-y: auto;
      font-size: 14px;
    }

    .chat-msg {
      margin-bottom: 8px;
    }

    .you {
      color: #0d6efd;
      font-weight: bold;
    }

    .ai {
      color: green;
      font-weight: bold;
    }
  </style>
</head>

<body class="bg-light">

<div class="container py-4">

  <h2 class="mb-4">Dashboard Produk</h2>

  <!-- PRODUK -->
  <div class="card mb-4">
    <div class="card-header bg-primary text-white">
      Produk
    </div>
    <div class="card-body p-0">
      <table class="table table-striped mb-0">
        <thead class="table-dark">
          <tr>
            <th>Nama</th>
            <th>Harga</th>
            <th>Stock</th>
          </tr>
        </thead>
        <tbody>
          <% produk.forEach(p => { %>
            <tr>
              <td><%= p.nama %></td>
              <td>Rp <%= p.harga %></td>
              <td><%= p.qty %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- PEMBELIAN -->
  <div class="card mb-4">
    <div class="card-header bg-success text-white">
      Pembelian
    </div>

    <div class="card-body">
      <form action="/produk/beli" method="POST" class="row g-2">

        <div class="col-md-6">
          <select name="produk_id" class="form-select">
            <% produk.forEach(p => { %>
              <option value="<%= p.id %>"><%= p.nama %></option>
            <% }) %>
          </select>
        </div>

        <div class="col-md-3">
          <input type="number" name="qty" class="form-control" placeholder="Qty">
        </div>

        <div class="col-md-3">
          <button class="btn btn-success w-100">Beli</button>
        </div>

      </form>
    </div>
  </div>

  <!-- DATA PEMBELIAN -->
  <div class="card">
    <div class="card-header bg-warning">
      Data Pembelian
    </div>

    <div class="card-body p-0">
      <table class="table table-bordered mb-0">
        <thead class="table-dark">
          <tr>
            <th>Produk</th>
            <th>Qty</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>

        <tbody>
          <% pembelian.forEach(p => { %>
            <tr>
              <td><%= p.nama %></td>
              <td><%= p.qty %></td>
              <td><%= p.status %></td>
              <td>
                <% if (p.status !== 'cancel') { %>
                  <a href="/produk/cancel/<%= p.id %>" class="btn btn-sm btn-danger">Cancel</a>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>

      </table>
    </div>
  </div>

</div>

<!-- CHAT BUTTON -->
<div id="chatButton" onclick="toggleChat()">
  💬
</div>

<!-- CHAT POPUP -->
<div id="chatPopup">

  <div class="bg-primary text-white p-2">
    Chatbot AI
  </div>

  <div id="chatBox"></div>

  <div class="d-flex border-top">
    <input id="message" class="form-control border-0" placeholder="Tulis pesan...">
    <button onclick="sendMessage()" class="btn btn-primary">➤</button>
  </div>

</div>

<!-- SCRIPT -->
<script>
function toggleChat() {
  const popup = document.getElementById("chatPopup");
  popup.style.display = popup.style.display === "flex" ? "none" : "flex";
}

async function sendMessage() {
  const input = document.getElementById("message");
  const message = input.value;
  if (!message) return;

  const box = document.getElementById("chatBox");

  box.innerHTML += `<div class="chat-msg"><span class="you">You:</span> ${message}</div>`;

  input.value = "";

  const res = await fetch("/chat", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ message })
  });

  const data = await res.json();

  box.innerHTML += `<div class="chat-msg"><span class="ai">AI:</span> ${data.reply}</div>`;

  box.scrollTop = box.scrollHeight;
}
</script>

</body>
</html>